{
  "info": {
    "name": "HIS API Test Collection",
    "description": "HIS医院信息管理系统接口测试集合",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8080/hoso",
