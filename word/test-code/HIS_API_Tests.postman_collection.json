    {
      "name": "2. 新增用户接口测试",
      "item": [
        {
          "name": "TC-INSERT-001 正常新增用户-完整信息",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "var timestamp = Date.now();",
                  "pm.variables.set('timestamp', timestamp);"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('状态码为200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('返回status为OK', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.status).to.eql('OK');",
                  "});",
                  "",
                  "pm.test('返回userId', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.data).to.have.property('userId');",
                  "    pm.variables.set('user_id', jsonData.data.userId);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"userLoginname\": \"testuser_{{timestamp}}\",\n    \"userPassword\": \"123456\",\n    \"roleId\": 3,\n    \"userName\": \"测试用户{{timestamp}}\",\n    \"departmentId\": 1,\n    \"userTitleId\": 9,\n    \"userGender\": \"男\",\n    \"userStatus\": \"ACTIVE\",\n    \"userSchedulingLimitcount\": 50\n}"
            },
            "url": {
              "raw": "{{base_url}}/user/insert",
              "host": ["{{base_url}}"],
              "path": ["user", "insert"]
            }
          },
          "response": []
        },
