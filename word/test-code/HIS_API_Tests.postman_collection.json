  "item": [
    {
      "name": "1. 登录接口测试",
      "item": [
        {
          "name": "TC-LOGIN-001 管理员正常登录",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{base_url}}/login/LoginUser?userLoginName=admin&password=admin123",
              "host": ["{{base_url}}"],
              "path": ["login", "LoginUser"],
              "query": [
                {
                  "key": "userLoginName",
                  "value": "admin"
                },
                {
                  "key": "password",
                  "value": "admin123"
                }
              ]
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('状态码为200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('返回status为OK', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.status).to.eql('OK');",
                  "});",
                  "",
                  "pm.test('返回用户信息', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.data).to.have.property('user');",
                  "    pm.expect(jsonData.data.user.userLoginname).to.eql('admin');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "TC-LOGIN-002 医生用户正常登录",
